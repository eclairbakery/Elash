#include std "io.elh"
#include std "img/png.elh"

#define A 123
#note "siema"

#if defined(A)
    #if A == 123 
        #define A_IS_123 true
    #else
        #define A_IS_123 false
    #endif
#endif

#if A_IS_123
    #include <sys-header.elh>
    #include "a-is-123.elh"
#else
    #include "nah.elh"
#endif

#define CREATE_ENUM(NAME, ENUMERATORS):
    typedef enum NAME {
    #foreach enumerator: ENUMERATORS
        #emit enumerator
    #endfor
    } NAME;

    char[*][] NAME_names = {
    #foreach enumerator: ENUMERATORS
        #emit stringify(enumerator)
    #endfor
    };
#enddef

const byte[] elash_logo = #embed "../assets/logo.png";
const usize elash_logo_size = sizeof(elash_logo);

int main() { 
    PngImg png = PngImg::LoadFromMem(elash_logo, elash_logo_size);
    #ifdef DEBUG_BUILD
        printlnf("Image size: ", png.getSize());
    #endif
    png.paintRect({ { 100, 100 }, { 300, 150 } }, Color::Black);
    png.save("output.png");
 
    return 0;
}
